      "sans": { "font": "Inter", "weights": [300, 400, 500, 600, 700], "tailwind": "font-sans", "usage": "Body text, H3-H5" },
      "heading": { "font": "Bricolage Grotesque", "weights": [300, 400, 500, 600, 700], "tailwind": "font-heading", "usage": "H1-H2 headings" },
      "mono": { "font": "ui-monospace, SFMono-Regular, Menlo", "tailwind": "font-mono", "usage": "Code blocks" },
      "serif": { "font": "ui-serif, Georgia", "tailwind": "font-serif", "usage": "Decorative (rarely used)" }
    },
    "headings": {
      "h1": { "family": "Bricolage Grotesque", "weight": 500, "classes": "font-heading font-medium" },
      "h2": { "family": "Bricolage Grotesque", "weight": 500, "classes": "font-heading font-medium" },
