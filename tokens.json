      "tooltip": { "bg": { "light": "purple-600", "dark": "purple-600", "tailwind": "tooltip" } },

      "chart": {
        "1": { "light": "purple-400", "dark": "purple-400" },
        "2": { "light": "green-500", "dark": "green-400" },
