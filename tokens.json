  "spacing": {
    "$description": "8-point grid scale. Always use sp- prefix tokens.",
    "scale": {
      "sp-4": { "value": "4px", "tailwind": "sp-4" },
      "sp-8": { "value": "8px", "tailwind": "sp-8" },
      "sp-12": { "value": "12px", "tailwind": "sp-12" },
      "sp-16": { "value": "16px", "tailwind": "sp-16" },
      "sp-24": { "value": "24px", "tailwind": "sp-24" },
      "sp-32": { "value": "32px", "tailwind": "sp-32" },
      "sp-40": { "value": "40px", "tailwind": "sp-40" },
      "sp-48": { "value": "48px", "tailwind": "sp-48" },
      "sp-64": { "value": "64px", "tailwind": "sp-64" },
      "sp-96": { "value": "96px", "tailwind": "sp-96" },
