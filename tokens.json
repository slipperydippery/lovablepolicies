{
  "$schema": "Elari Design System — design tokens extracted from src/index.css and tailwind.config.ts",
  "$name": "Elari Design System",
  "$version": "2.0.0",

  "rules": [
    "Never use primitive color tokens directly in components — always use semantic tokens",
    "Always use sp- prefix spacing tokens (e.g., sp-8, sp-16) instead of raw Tailwind numbers",
    "All colors must be HSL-based via CSS variables",
    "Use design system shadow tokens instead of Tailwind shadow utilities",
    "Only use Font Awesome icons from the design system — no external icon libraries"
