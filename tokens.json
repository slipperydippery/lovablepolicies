    "semantic": {
      "$description": "Functional tokens — use these in components. Maps to primitives via CSS variables.",

      "brand": {
        "primary": { "light": "purple-400 (Wisteria #AC8BF3)", "dark": "purple-400", "tailwind": "primary", "token": "--primary" },
        "primary-foreground": { "light": "0 0% 100%", "dark": "0 0% 100%", "tailwind": "primary-foreground" },
        "secondary": { "light": "blue-500 (Sapphire #355EBF)", "dark": "blue-400", "tailwind": "secondary" },
        "secondary-foreground": { "light": "0 0% 100%", "dark": "0 0% 100%", "tailwind": "secondary-foreground" },
        "accent": { "light": "purple-200 (Lilac)", "dark": "purple-300", "tailwind": "accent" },
        "accent-foreground": { "light": "purple-800", "dark": "0 0% 100%", "tailwind": "accent-foreground" }
      },

